# Frontend API base URL.
# Defaults to http://localhost:8787 if omitted.
VITE_API_BASE_URL="http://localhost:8787"

# Google OAuth client ID (web client) for "Sign in with Google".
VITE_GOOGLE_CLIENT_ID="your_google_client_id"

# Optional: Amazon affiliate tag for "shop missing item" links.
VITE_AMAZON_ASSOCIATE_TAG="yourtag-20"
